# ─── Database ─────────────────────────────────────────────────────────────────
# Password for the local PostgreSQL container
POSTGRES_PASSWORD=changeme

# Full connection string (auto-built by docker-compose; override only if using external DB)
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/claude_dashboard

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# The URL where the app is reachable (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Anthropic Admin API ──────────────────────────────────────────────────────
# Must be an Admin key (sk-ant-admin01-...), NOT a regular API key
# Get it from: https://console.anthropic.com/settings/admin-keys
ANTHROPIC_ADMIN_KEY=sk-ant-admin01-...
