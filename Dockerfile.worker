FROM node:20-alpine AS base
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Install worker deps
COPY sync-worker/package.json ./
RUN npm install

# Copy Prisma schema and generate client
COPY prisma ./prisma
RUN npx prisma generate

# Copy worker source
COPY sync-worker/index.js ./

CMD ["node", "index.js"]
